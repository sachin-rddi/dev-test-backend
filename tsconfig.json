{
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["es2022"],
    "removeComments": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "module": "commonjs",
    "noEmit": false,
    "noUnusedParameters": false,
    "sourceMap": true,
    "target": "es2022",
    "strict": true,
    "outDir": "lib",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths":
      {
        "@*": ["./*"],
        "@shared/*": ["./shared/*"],
        "@backend/*": ["./backend/*"]
      }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", ".terraform/**/*"]
}
